# 技能目录 Git 忽略规则

# ==================== 工作目录 ====================
# 搬题姬等技能的临时工作目录
work/
temp_extract/
temp/

# ==================== 打包文件 ====================
# 题目打包文件
*.zip
*.tar.gz

# ==================== 可执行文件 ====================
# C/C++ 编译产物
*.exe
*.out
*.o
*.a
std
mkdata

# ==================== Python 缓存 ====================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# ==================== Node.js ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== 系统文件 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ==================== IDE/编辑器 ====================
# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
.*.swp

# ==================== 缓存文件 ====================
# 嵌入缓存
embedding_cache/
.cache/

# 模型缓存
models/
*.model
*.bin

# ==================== 日志文件 ====================
*.log
logs/

# ==================== 标记文件 ====================
.bootstrap_completed
.reme_store_v1

# ==================== 数据库文件 ====================
*.db
*.sqlite
*.sqlite3

# ==================== 其他临时文件 ====================
*.tmp
*.temp
*.bak
*.backup
*.orig